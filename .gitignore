/node_modules
# macOS Finder metadata — never commit these
.DS_Store
**/.DS_Store
# build output
dist/
# Supabase CLI machine-local cache
supabase/.temp/
.image-backup/
# Local env files (Vite reads VITE_* into the client at build time — never
# commit real values). .env.example IS tracked.
.env
.env.local
.env.*.local
# Cartoon banner webps — served from Supabase Storage CDN, not git.
# Generate locally with: node scripts/generate-card-art.mjs
# Upload to CDN with:    node scripts/upload-cartoon-banners.mjs
public/cartoon-banners/
# Preview thumbnails generated by generate-card-art.mjs — local review only, not deployed.
public/preview-card-art/
# Master generated art output (source + grid previews) — large local artifact, not deployed.
scripts/generated-card-art/
# Claude Code: local worktrees and patch backups — these never belong in develop.
.claude/worktrees/
.claude/worktree-changes.patch
scripts/cartoon-banners-backup/
