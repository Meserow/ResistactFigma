# ResistAct — environment variables
# Copy this file to .env (which is gitignored) and fill in real values.
# Vite only exposes variables prefixed with VITE_ to the client.

# ─── Google Analytics 4 ──────────────────────────────────────────────────────
# Format: G-XXXXXXXXXX. Leave empty to disable analytics entirely (no scripts
# loaded, no network calls, no cookies). The analytics module also automatically
# disables when the visitor's browser has Do-Not-Track set, regardless of this
# value.
VITE_GA_MEASUREMENT_ID=
